{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "cross-env NODE_ENV=production bun src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun --minify",
    "serve": "bun dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "bunx prisma generate",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:deploy": "bunx prisma migrate deploy",
    "prisma:reset": "bunx prisma migrate reset",
    "prisma:studio": "bunx prisma studio",
    "prisma:format": "bunx prisma format",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "rimraf dist",
    "postinstall": "bunx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "amqplib": "^2.0.1",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^10.0.3",
    "prisma": "6.19.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.2"
  }
}
